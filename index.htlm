<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CreaTech Formation</title>

<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'DM Sans', sans-serif;
  background: #0C0F1C;
  color: #F7F6F2;
}

header {
  padding: 30px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

h1 {
  font-family: 'Syne', sans-serif;
  font-size: 32px;
}

.hero {
  height: 250px;
  background: url('https://images.unsplash.com/photo-1580894732444-8ecded7900cd?w=1200') center/cover;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.hero h2 {
  font-size: 28px;
  background: rgba(0, 0, 0, 0.6);
  padding: 10px 20px;
}

.section {
  padding: 30px;
}

.card {
  background: #111627;
  padding: 20px;
  margin-bottom: 20px;
  border-radius: 10px;
}

.card h3 {
  margin-top: 0;
}

.card img {
  width: 100%;
  border-radius: 10px;
  margin-top: 10px;
}

.footer {
  padding: 20px;
  text-align: center;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

/* WhatsApp Button */
.whatsapp-btn {
  position: fixed;
  bottom: 20px;
  right: 20px;
  background: #25D366;
  color: white;
  padding: 12px 16px;
  border-radius: 50px;
  text-decoration: none;
  font-weight: 500;
  box-shadow: 0 4px 15px rgba(0,0,0,0.3);
  z-index: 999;
}
</style>
</head>
<body>

<header>
  <h1>CREA<span style="color:#00FFE8">TECH</span></h1>
  <div>Session 2026</div>
</header>

<div class="hero">
  <h2>Apprenez aujourd'hui, brillez demain</h2>
</div>

<div class="section">
  <div class="card">
    <h3>💻 Informatique</h3>
    <p>Word, Excel, PowerPoint, HTML, JavaScript, Langage C</p>
  </div>

  <div class="card">
    <h3>🤖 Intelligence Artificielle</h3>
    <p>Utiliser l'IA pour résoudre des problèmes et booster sa productivité</p>
  </div>

  <div class="card">
    <h3>🎨 Résine Époxy & Perlage</h3>
    <img src="https://images.unsplash.com/photo-1603575448364-bf62b4c4f7a5?w=800" alt="Résine Époxy & Perlage">
    <p>Création d'objets, bijoux et décoration</p>
  </div>

  <div class="card">
    <h3>⚙️ Robotique</h3>
    <p>Fabrication et programmation de robots</p>
  </div>

  <div class="card">
    <h3>🔧 Mécanique Automobile</h3>
    <p>Diagnostic et entretien de véhicules</p>
  </div>
</div>

<div class="footer">
  📞 677 065 865 / 693 330 888 <br>
  📍 PK10 - Douala
</div>

<!-- WhatsApp Button -->
<a href="https://wa.me/237677065865?text=Bonjour%2C%20je%20veux%20des%20informations%20sur%20vos%20formations" target="_blank" class="whatsapp-btn">
  💬 WhatsApp
</a>

</body>
</html>
